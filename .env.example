# Copy to ~/.nostr-merchant/.env (XDG path) and fill in.
# .env in this directory is for development only and gitignored.

# --- LLM backend --------------------------------------------------------
# Pydantic AI model string: '<provider>:<model>'. Recognized providers:
#   ollama       (recommended for sovereignty audience — local, no API keys)
#   anthropic    (best tool use; requires ANTHROPIC_API_KEY)
#   openai       (requires OPENAI_API_KEY)
#   google-gla / groq / mistral (also supported by pydantic-ai)
NOSTR_MERCHANT_MODEL=ollama:qwen3:8b

# OLLAMA_BASE_URL=http://localhost:11434/v1
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...

# --- MCP servers --------------------------------------------------------
# Two ways to point the agent at the substrate. Pick one (or neither for
# the npx fallback).
#
# (A) DEV / LOCAL — set NOSTR_MERCHANT_SUBSTRATE_ROOT to the parent directory that
# contains the five MCP-server build directories as siblings. Each server
# is launched as `node <root>/<name>/dist/index.js` so it reads its own
# `.env` from its own build directory. Cleanest setup for the substrate's
# author / contributors.
# NOSTR_MERCHANT_SUBSTRATE_ROOT=/home/me/code/llmops-pro
#
# (B) FULL OVERRIDE — set NOSTR_MERCHANT_MCP_SERVERS to a JSON array of specs.
# NOSTR_MERCHANT_MCP_SERVERS=[{"name":"nwc","command":"npx","args":["-y","nwc-mcp"]}, ...]
#
# (C) NPX FALLBACK — leave both unset. Agent uses `npx -y <name>` and the
# substrate servers pick up their config from the PARENT PROCESS env (so
# you'd need NWC_CONNECTION_STRING, NOSTR_RELAYS, etc. set in this same
# .env — but watch out for env collisions when several servers share var
# names).
#
# Optional: skip one or more servers from whichever default set (B or C)
# is in use. Useful when one server's config is broken or its upstream is
# unavailable. CSV of names: nwc / nostr / marketplace / albyhub / paywall.
# Has NO effect when NOSTR_MERCHANT_MCP_SERVERS (A) is set — that's a full override.
# NOSTR_MERCHANT_SUBSTRATE_SKIP=albyhub

# --- Agent-layer safety knobs ------------------------------------------
# Disables all priced tool calls. Useful for dry runs / review mode.
# AGENT_READ_ONLY=false

# Per-task budget (single `nostr-merchant ask` invocation).
# AGENT_MAX_SATS_PER_TASK=100

# Rolling 24h budget across all tasks.
# AGENT_MAX_SATS_PER_DAY=1000

# Refuse any individual paid tool whose invoice asks more than this,
# regardless of remaining budget.
# AGENT_MAX_TOOL_PRICE=500

# Optional CSV: when set, only listed tools are callable (free or paid).
# AGENT_TOOL_ALLOWLIST=nwc_get_balance,nwc_pay_invoice,bitcoin_block_height

# In interactive mode, pause and ask before paying any tool above this.
# AGENT_CONFIRM_THRESHOLD_SATS=100

# --- Logging / persistence ---------------------------------------------
# AGENT_AUDIT_PATH=~/.nostr-merchant/audit.log
# AGENT_BUDGET_PATH=~/.nostr-merchant/budget.json
# AGENT_LOG_LEVEL=INFO
